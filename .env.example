# ── Gmail (Upworkアラートメールを読むため) ──────────────────────────────────
# GmailのメールアドレスとGoogleアプリパスワード（通常パスワードではない）
#
# アプリパスワードの作成手順:
#   1. https://myaccount.google.com/security を開く
#   2. 「2段階認証プロセス」をONにする（まだの場合）
#   3. 「2段階認証プロセス」のページ下部「アプリパスワード」をクリック
#   4. アプリ名に「upwork-scraper」など適当な名前を入れて「作成」
#   5. 表示された16文字のパスワードをここに貼る（スペースなしで）
GMAIL_EMAIL=ar.seiichi.1029@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ── DeepSeek API ───────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Discord Webhook ───────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx
